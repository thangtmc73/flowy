
# === Multi-Partner Knowledge Base ===
# FAQ_DATA_PATH defaults to "knowledge" (new multi-partner structure)
# If you want to use old format, set to "knowledge/faq.json"
FAQ_DATA_PATH=knowledge

# === Memory Configuration ===
MEMORY_ID=your_memory_id_here
MEMORY_STRATEGY_ID=default

# === LLM Configuration ===
LLM_MODEL=your_model_name
LLM_BASE_URL=https://your-llm-provider.com/v1
LLM_API_KEY=your_api_key_here

# === GreenNode AgentBase ===
GREENNODE_CLIENT_ID=your_client_id
GREENNODE_CLIENT_SECRET=your_client_secret

# === Agent Runtime ===
AGENT_PORT=8080
